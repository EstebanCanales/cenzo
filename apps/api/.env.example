# Censo API — variables de entorno (copiar a apps/api/.env y completar).
# El .env real está gitignored (contiene la llave secreta admin).

STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Contract id desplegado (stellar contract deploy ...)
CENSO_CONTRACT_ID=C...

# Llave admin custodial. ADMIN_KEY_NAME = alias de `stellar keys` usado para firmar.
# ADMIN_SECRET_KEY = seed S... (solo referencia; el CLI firma vía el alias).
ADMIN_SECRET_KEY=S...
ADMIN_KEY_NAME=censo-admin

# SQLite (path relativo al crate apps/api). Producción puede usar Postgres.
DATABASE_URL=sqlite://censo.db?mode=rwc

API_PORT=4000

# Secreto compartido server-a-server. El proxy Next.js lo adjunta en x-api-key
# para rutas de escritura. Vacío = sin gate (solo dev).
API_SHARED_SECRET=
