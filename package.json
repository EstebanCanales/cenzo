{
  "name": "censo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:api": "cargo run --manifest-path apps/api/Cargo.toml",
    "build:api": "cargo build --manifest-path apps/api/Cargo.toml"
  }
}

